<!DOCTYPE html>
<html lang="es">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}Gestión de proveedores{% endblock %}</title>
        <link rel="stylesheet" href="{{ asset('assets/css/app.css') }}">
        {% block stylesheets %}{% endblock %}
    </head>
    <body>
        {% block header %}
            <header class="site-header">
                <nav class="site-nav">
                    <a class="site-logo" href="{{ path('proveedor_listado') }}">Gestión de proveedores</a>

                    <div class="site-nav__links">
                        <a href="#">Proveedores</a>
                        {% if app.user %}
                            <a class="logout-link" href="{{ path('app_logout') }}" aria-label="Cerrar sesión" title="Cerrar sesión">
                                <svg viewBox="0 0 24 24" aria-hidden="true">
                                    <path d="M10 17l5-5-5-5"></path>
                                    <path d="M15 12H3"></path>
                                    <path d="M21 19V5a2 2 0 0 0-2-2h-6"></path>
                                    <path d="M13 21h6a2 2 0 0 0 2-2"></path>
                                    <path d="M13 3h6a2 2 0 0 1 2 2"></path>
                                </svg>
                            </a>
                        {% endif %}
                    </div>
                </nav>
            </header>
        {% endblock %}

        <main class="site-main">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash--{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <script src="{{ asset('assets/js/app.js') }}"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
